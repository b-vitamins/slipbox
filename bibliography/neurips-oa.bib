  title = {Simplicial Mixtures of Markov Chains: Distributed Modelling of Dynamic User Profiles},
  url = {https://proceedings.neurips.cc/paper_files/paper/2003/file/4a8423d5e91fda00bb7e46540e2b0cf1-Paper.pdf},
  volume = {16},
