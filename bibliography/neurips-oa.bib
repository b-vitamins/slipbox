  title = {Stochastic Gradient Riemannian Langevin Dynamics on the Probability Simplex},
  url = {https://proceedings.neurips.cc/paper_files/paper/2013/file/309928d4b100a5d75adff48a9bfc1ddb-Paper.pdf},
