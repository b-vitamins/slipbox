@inproceedings{NIPS2001_52dbb068,
  abstract = {The problem of searching for information in networks like the World Wide Web can be approached in a variety of ways, ranging from centralized indexing schemes to decentralized mechanisms that navigate the underlying network without knowledge of its global structure. The decentralized approach appears in a variety of settings: in the behavior of users browsing the Web by following hyperlinks; in the design of focused crawlers \cite{4}, \cite{5}, \cite{8} and other agents that explore the Web's links to gather information; and in the search protocols underlying decentralized peer-to-peer systems such as Gnutella \cite{10}, Freenet \cite{7}, and recent research prototypes \cite{21}, \cite{22}, \cite{23}, through which users can share resources without a central server.},
